{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "include-component-in-tag": true,
  "release-search-depth": 20,
  "commit-search-depth": 50,
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "galeharness-cli",
      "components": ["cli", "galeharness-cli"]
    }
  ],
  "packages": {
    ".": {
      "release-type": "simple",
      "package-name": "cli",
      "exclude-paths": [
        "AGENTS.md",
        "CLAUDE.md",
        "README.md",
        "LICENSE",
        "SECURITY.md",
        "PRIVACY.md",
        "favicon.png",
        "docs/",
        "scripts/",
        ".github/",
        ".claude/",
        ".codex/",
        ".agents/",
        ".gemini/",
        ".cursor/",
        ".windsurf/",
        ".claude-plugin/",
        ".cursor-plugin/",
        "plugins/"
      ],
      "extra-files": [
        {
          "type": "json",
          "path": "package.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "plugins/galeharness-cli": {
      "release-type": "simple",
      "package-name": "galeharness-cli",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": ".cursor-plugin/plugin.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "plugins/coding-tutor": {
      "release-type": "simple",
      "package-name": "coding-tutor",
      "extra-files": [
        {
          "type": "json",
          "path": ".claude-plugin/plugin.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": ".cursor-plugin/plugin.json",
          "jsonpath": "$.version"
        }
      ]
    },
    ".claude-plugin": {
      "release-type": "simple",
      "package-name": "marketplace",
      "extra-files": [
        {
          "type": "json",
          "path": "marketplace.json",
          "jsonpath": "$.metadata.version"
        }
      ]
    },
    ".cursor-plugin": {
      "release-type": "simple",
      "package-name": "cursor-marketplace",
      "extra-files": [
        {
          "type": "json",
          "path": "marketplace.json",
          "jsonpath": "$.metadata.version"
        }
      ]
    }
  }
}
